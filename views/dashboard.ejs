<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard - Career Bridge</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
  <!-- Custom Dashboard CSS -->
  <link href="/css/dashboard.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/header') %>

  <!-- Dashboard Header -->
  <div class="container mt-4">
    <div class="dashboard-header text-center">
      <h2>Welcome, <%= user.name %> 👋</h2>
      <p class="mb-0">Here’s a quick look at your career journey</p>
    </div>
  </div>

  <!-- Stats Section -->
  <div class="container mt-5">
    <div class="row g-4 text-center">
      <div class="col-md-4">
        <div class="card p-4">
          <i class="bi bi-briefcase stat-icon"></i>
          <h4 class="mt-3">Applications</h4>
          <p class="text-muted">12 Applied</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card p-4">
          <i class="bi bi-graph-up stat-icon"></i>
          <h4 class="mt-3">Profile Match</h4>
          <p class="text-muted">87% Average Fit</p>
        </div>
      </div>
      <div class="col-md-4">
        <div class="card p-4">
          <i class="bi bi-bell stat-icon"></i>
          <h4 class="mt-3">Notifications</h4>
          <p class="text-muted">3 New Opportunities</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Opportunities & Actions -->
  <div class="container mt-5">
    <div class="row g-4">
      <!-- Opportunities -->
      <div class="col-md-8">
        <div class="card p-4">
          <h4>Recommended Opportunities</h4>
          <ul class="list-group list-group-flush mt-3">
            <li class="list-group-item d-flex justify-content-between align-items-center">
              Data Analyst Internship at XYZ Corp
              <span class="badge bg-success">92% Match</span>
            </li>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              Frontend Developer at ABC Tech
              <span class="badge bg-warning">75% Match</span>
            </li>
            <li class="list-group-item d-flex justify-content-between align-items-center">
              ML Research Assistant at University Labs
              <span class="badge bg-info">81% Match</span>
            </li>
          </ul>
        </div>
      </div>

      <!-- Quick Actions -->
      <div class="col-md-4">
        <div class="card p-4">
          <h4>Quick Actions</h4>
          <a href="/resume/upload" class="btn btn-success w-100 mb-2">
            <i class="bi bi-upload"></i> Upload Resume
          </a>
          <a href="/auth/logout" class="btn btn-outline-danger w-100">
            <i class="bi bi-box-arrow-right"></i> Logout
          </a>
        </div>
      </div>
    </div>
  </div>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
