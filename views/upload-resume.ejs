<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Upload Resume - Career Bridge</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/header') %>

  <div class="container mt-5">
    <h2 class="text-center">Upload Your Resume</h2>
    <form class="mt-4 col-md-6 mx-auto" enctype="multipart/form-data">
      <input type="file" class="form-control mb-3" accept=".pdf,.doc,.docx" required>
      <button type="submit" class="btn btn-success w-100" disabled>Upload & Analyze (coming soon)</button>
    </form>
  </div>

  <%- include('partials/footer') %>
</body>
</html>
