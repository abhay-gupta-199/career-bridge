<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Career Bridge - Find Your Perfect Opportunity</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
  <%- include('partials/header') %>

  <!-- Hero Section -->
  <section class="hero text-center text-white d-flex align-items-center">
    <div class="container">
      <h1 class="fw-bold">Find the Right Opportunities, Just for You 🚀</h1>
      <p class="lead">AI-powered platform to match your resume with real jobs, internships & scholarships.</p>
      <% if (!isAuthenticated) { %>
        <a href="/auth/signup" class="btn btn-primary btn-lg mt-3">Get Started Free</a>
        <a href="/auth/login" class="btn btn-outline-light btn-lg mt-3">Login</a>
      <% } else { %>
        <a href="/dashboard" class="btn btn-primary btn-lg mt-3">Go to Dashboard</a>
      <% } %>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-5">
    <div class="container text-center">
      <h2 class="mb-4">Why Choose Career Bridge?</h2>
      <div class="row g-4">
        <div class="col-md-3"><div class="card feature-card p-4">🔍 Resume Matching</div></div>
        <div class="col-md-3"><div class="card feature-card p-4">📢 Push Notifications</div></div>
        <div class="col-md-3"><div class="card feature-card p-4">📊 Skill Gap Analysis</div></div>
        <div class="col-md-3"><div class="card feature-card p-4">📈 Weekly Reports</div></div>
      </div>
    </div>
  </section>

  <!-- How It Works -->
  <section id="howitworks" class="py-5 bg-light text-center">
    <div class="container">
      <h2>How It Works</h2>
      <div class="row mt-4">
        <div class="col-md-4">1️⃣ Upload Resume</div>
        <div class="col-md-4">2️⃣ Get Matches</div>
        <div class="col-md-4">3️⃣ Apply & Grow</div>
      </div>
    </div>
  </section>

  <%- include('partials/footer') %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
